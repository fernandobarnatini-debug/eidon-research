{
  "rewrites": [
    { "source": "/api/orders", "destination": "/api/orders" },
    { "source": "/api/order", "destination": "/api/order" },
    { "source": "/api/pay", "destination": "/api/pay" },
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/api/track", "destination": "/api/track" },
    { "source": "/api/analytics", "destination": "/api/analytics" },
    { "source": "/api/analytics/realtime", "destination": "/api/analytics-realtime" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
